# Local development secrets/config (do not commit real values)

# Primary provider: `openai` or `gemini`
FLO_AI_PROVIDER=openai

# API-key modes (set one based on FLO_AI_PROVIDER)
FLO_OPENAI_API_KEY=
FLO_GEMINI_API_KEY=

# Optional OAuth overrides (Codex-style defaults are built in)
FLO_CHATGPT_OAUTH_ENABLED=true
# FLO_CHATGPT_AUTH_URL=https://auth.openai.com/oauth/authorize
# FLO_CHATGPT_TOKEN_URL=https://auth.openai.com/oauth/token
# FLO_CHATGPT_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# FLO_CHATGPT_CLIENT_SECRET=
# FLO_CHATGPT_REDIRECT_URI=http://localhost:1455/auth/callback
# FLO_CHATGPT_SCOPES=openid profile email offline_access
# FLO_CHATGPT_ORIGINATOR=pi

# Optional models and behavior
FLO_OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
FLO_OPENAI_TTS_MODEL=gpt-4o-mini-tts
FLO_OPENAI_REWRITE_MODEL=gpt-4o-mini
FLO_OPENAI_TTS_VOICE=alloy
FLO_GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview
FLO_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
FLO_GEMINI_REWRITE_MODEL=gemini-2.0-flash
FLO_GEMINI_TTS_VOICE=Kore
# Optional endpoint overrides
# FLO_OPENAI_REWRITE_URL=https://api.openai.com/v1/chat/completions
# FLO_GEMINI_REWRITE_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
FLO_TTS_SPEED=1.0
FLO_TTS_CHUNK_SIZE=1500
FLO_HOST_ALLOWLIST=api.openai.com,generativelanguage.googleapis.com
FLO_RETAIN_AUDIO_DEBUG=false

# Optional degraded mode flags
FLO_FEATURE_GLOBAL_HOTKEYS=true
FLO_FEATURE_DICTATION=true
FLO_FEATURE_READ_ALOUD=true
