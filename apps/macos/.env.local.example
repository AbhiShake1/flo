# Local development secrets/config (do not commit real values)

# Provider routing order (first is primary). Falls back on retryable errors.
FLO_AI_PROVIDER_ORDER=openai,gemini,openrouter,groq,xai,deepinfra,together,perplexity
# Backward-compatible single provider selector (used when FLO_AI_PROVIDER_ORDER is unset)
FLO_AI_PROVIDER=openai

# API keys (single key or comma-separated key pool per provider)
FLO_OPENAI_API_KEY=
FLO_OPENAI_API_KEYS=
FLO_GEMINI_API_KEY=
FLO_GEMINI_API_KEYS=
FLO_OPENROUTER_API_KEY=
FLO_OPENROUTER_API_KEYS=
FLO_GROQ_API_KEY=
FLO_GROQ_API_KEYS=
FLO_XAI_API_KEY=
FLO_XAI_API_KEYS=
FLO_DEEPINFRA_API_KEY=
FLO_DEEPINFRA_API_KEYS=
FLO_TOGETHER_API_KEY=
FLO_TOGETHER_API_KEYS=
FLO_PERPLEXITY_API_KEY=
FLO_PERPLEXITY_API_KEYS=

# Optional OAuth overrides (Codex-style defaults are built in)
FLO_CHATGPT_OAUTH_ENABLED=true
# FLO_CHATGPT_AUTH_URL=https://auth.openai.com/oauth/authorize
# FLO_CHATGPT_TOKEN_URL=https://auth.openai.com/oauth/token
# FLO_CHATGPT_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# FLO_CHATGPT_CLIENT_SECRET=
# FLO_CHATGPT_REDIRECT_URI=http://localhost:1455/auth/callback
# FLO_CHATGPT_SCOPES=openid profile email offline_access
# FLO_CHATGPT_ORIGINATOR=pi

# Optional models and behavior
FLO_OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
FLO_OPENAI_TTS_MODEL=gpt-4o-mini-tts
FLO_OPENAI_REWRITE_MODEL=gpt-4o-mini
FLO_OPENAI_TTS_VOICE=alloy
FLO_GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview
FLO_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
FLO_GEMINI_REWRITE_MODEL=gemini-2.0-flash
FLO_GEMINI_TTS_VOICE=Kore
FLO_OPENROUTER_REWRITE_MODEL=openai/gpt-4o-mini
FLO_GROQ_REWRITE_MODEL=llama-3.3-70b-versatile
FLO_XAI_REWRITE_MODEL=grok-3-mini
FLO_DEEPINFRA_REWRITE_MODEL=meta-llama/Llama-3.3-70B-Instruct
FLO_TOGETHER_REWRITE_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
FLO_PERPLEXITY_REWRITE_MODEL=sonar
# Optional endpoint overrides
# FLO_OPENAI_REWRITE_URL=https://api.openai.com/v1/chat/completions
# FLO_GEMINI_REWRITE_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
# FLO_OPENROUTER_REWRITE_URL=https://openrouter.ai/api/v1/chat/completions
# FLO_GROQ_REWRITE_URL=https://api.groq.com/openai/v1/chat/completions
# FLO_XAI_REWRITE_URL=https://api.x.ai/v1/chat/completions
# FLO_DEEPINFRA_REWRITE_URL=https://api.deepinfra.com/v1/openai/chat/completions
# FLO_TOGETHER_REWRITE_URL=https://api.together.xyz/v1/chat/completions
# FLO_PERPLEXITY_REWRITE_URL=https://api.perplexity.ai/chat/completions
FLO_TTS_SPEED=1.0
FLO_TTS_CHUNK_SIZE=1500
FLO_HOST_ALLOWLIST=api.openai.com,generativelanguage.googleapis.com,openrouter.ai,api.groq.com,api.x.ai,api.deepinfra.com,api.together.xyz,api.perplexity.ai
FLO_RETAIN_AUDIO_DEBUG=false

# Failover controls
FLO_FAILOVER_ALLOW_CROSS_PROVIDER=true
FLO_FAILOVER_MAX_ATTEMPTS=8
FLO_FAILOVER_FAILURE_THRESHOLD=2
FLO_FAILOVER_COOLDOWN_SECONDS=60
# Optional: restrict failover to a subset
# FLO_FAILOVER_ALLOWED_PROVIDERS=openai,gemini

# Optional degraded mode flags
FLO_FEATURE_GLOBAL_HOTKEYS=true
FLO_FEATURE_DICTATION=true
FLO_FEATURE_READ_ALOUD=true
